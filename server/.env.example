# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL 16 connection string (with PostGIS extension installed)
DATABASE_URL="postgresql://fixitnow_user:your_password@localhost:5432/fixitnow_db?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_this_to_a_random_256_bit_secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change_this_to_another_random_256_bit_secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:8080"

# ─── File Storage (Supabase Storage or S3) ───────────────────────────────────
STORAGE_BUCKET="fixitnow-uploads"
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
