# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL 16 connection string (with PostGIS extension installed)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/Fix-It?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_this_to_a_random_256_bit_secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change_this_to_another_random_256_bit_secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ─── File Storage (Supabase Storage or S3) ───────────────────────────────────
STORAGE_BUCKET="fixitnow-uploads"
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Ollama (local AI) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
